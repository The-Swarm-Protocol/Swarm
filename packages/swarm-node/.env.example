# Swarm Node Configuration

# Unique node identifier (generate a unique ID for each node)
NODE_ID=swarm-node-1

# Ethereum address of the compute provider
PROVIDER_ADDRESS=0x0000000000000000000000000000000000000000

# Firebase Admin credentials (Option 1: Individual environment variables)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Firebase Admin credentials (Option 2: Service account file path)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/serviceAccountKey.json

# Optional: Docker configuration
# DOCKER_HOST=unix:///var/run/docker.sock
