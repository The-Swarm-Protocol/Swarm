# ── Firebase (required) ──────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Thirdweb ────────────────────────────────────────────────────────────────
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=

# ── GitHub App ──────────────────────────────────────────────────────────────
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_WEBHOOK_SECRET=
NEXT_PUBLIC_GITHUB_APP_SLUG=

# ── Swarm LINK Contracts (Ethereum Sepolia) ─────────────────────────────────
# Populated by contracts/scripts/deploy.ts after deployment
NEXT_PUBLIC_LINK_AGENT_REGISTRY=
NEXT_PUBLIC_LINK_TASK_BOARD=
NEXT_PUBLIC_LINK_ASN_REGISTRY=
NEXT_PUBLIC_LINK_TREASURY=

# ── Platform Keys (SECRET — never expose client-side) ───────────────────────
SEPOLIA_PLATFORM_KEY=
HEDERA_PLATFORM_KEY=

# ── App Domain (canonical production origin for OAuth redirects) ────────
NEXT_PUBLIC_APP_DOMAIN=swarmprotocol.fun

# ── Upstash Redis (rate limiting, nonce replay protection, distributed locks) ─
UPSTASH_REDIS_REST_URL=       # e.g. https://us1-example.upstash.io
UPSTASH_REDIS_REST_TOKEN=     # Bearer token from Upstash console

# ── Session / Admin ─────────────────────────────────────────────────────────
SESSION_SECRET=
PLATFORM_ADMIN_SECRET=
INTERNAL_SERVICE_SECRET=
PLATFORM_ADMIN_WALLETS=
NEXT_PUBLIC_ADMIN_ADDRESS=

# ── OpenClaw (optional — only for workspace integration) ────────────────────
OPENCLAW_DIR=~/.openclaw
OPENCLAW_AGENT=main
WORKSPACE_DIR=
NEXT_PUBLIC_OPENCLAW_WORKSPACE=

# ── E2B Compute (cloud desktop sandboxes) ───────────────────────────────────
E2B_API_KEY=

# ── Azure Compute (primary cloud provider) ──────────────────────────────────
AZURE_SUBSCRIPTION_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# ── Storacha (decentralized storage — Protocol Labs Genesis Hackathon) ──────
STORACHA_AGENT_KEY=          # Ed25519 private key (npx ucan-key ed --json)
STORACHA_DELEGATION_PROOF=   # Base64 delegation proof from Storacha CLI
STORACHA_GATEWAY_DOMAIN=     # Optional IPFS gateway (default: storacha.link)

# ── Swarm Hub (Office Sim — real-time agent status) ──────────────────────────
SWARM_HUB_URL=               # Hub base URL (default: https://swarmprotocol.fun)
OFFICE_SIM_SERVICE_AGENT_ID= # Service agent ID for SSE relay (Ed25519 registered)
OFFICE_SIM_SERVICE_PRIVATE_KEY= # Ed25519 PEM private key for service agent

# ── AI Art Generation (Office Sim — Meshy.ai 3D + ComfyUI/Replicate 2D) ─────
MESHY_API_KEY=               # Meshy.ai API key for 3D model generation
COMFYUI_PROVIDER=            # "self-hosted" or "replicate" (default: self-hosted)
COMFYUI_ENDPOINT=            # Self-hosted ComfyUI URL for Office Sim mod (e.g. http://localhost:8188)
COMFYUI_CHECKPOINT=          # SDXL checkpoint (default: sd_xl_base_1.0.safetensors)
REPLICATE_API_TOKEN=         # Replicate API token (for cloud ComfyUI)

# ── ComfyUI Plugin (canonical Swarm integration) ─────────────────────────────
COMFYUI_BASE_URL=            # ComfyUI server URL (e.g. https://your-comfy-host)
COMFYUI_API_KEY=             # Optional Bearer token for ComfyUI auth proxy
