# ── Swarm Hub Configuration ──────────────────────────────────────────────────
# Copy to .env and fill in values before running the hub.

# Server
PORT=8400

# Security: Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=https://swarm.perkos.xyz,http://localhost:3000

# Firebase (required — no defaults)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_APP_ID=

# Firebase (optional)
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=

# Tuning (optional — sensible defaults built in)
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=60
MAX_CONNECTIONS_PER_AGENT=5
AUTH_WINDOW_MS=300000